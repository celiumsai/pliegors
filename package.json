{
  "name": "@pliego/pliegors-workspace",
  "version": "0.2.0-beta.1",
  "private": true,
  "type": "module",
  "scripts": {
    "bundle:phase-1-evidence": "node scripts/bundle-phase-1-evidence.mjs",
    "check:docs": "node scripts/check-doc-links.mjs",
    "check:product-truth": "node scripts/check-product-truth.mjs",
    "check:security-map": "node scripts/check-security-map.mjs",
    "check:g2-browser": "node scripts/check-g2-browser.mjs",
    "check:crates": "node scripts/publish-crates.mjs --check",
    "check:distribution": "node scripts/check-distribution.mjs",
    "check:benchmarks": "node scripts/check-benchmark-contract.mjs",
    "check:email-worker": "npm --prefix workers/pliegors-email run check",
    "check:fuzz": "node scripts/check-fuzz-contract.mjs",
    "check:golden-path": "node scripts/check-golden-matrix.mjs",
    "check:opensdk": "node scripts/check-opensdk-contract.mjs",
    "check:opensdk:multilang": "node scripts/check-opensdk-multilang.mjs",
    "check:opensdk:browser-frameworks": "node scripts/check-opensdk-browser-frameworks.mjs",
    "check:opensdk:tooling": "node scripts/check-opensdk-tooling.mjs",
    "check:opensdk:component-runtime": "node scripts/check-opensdk-component-runtime.mjs",
    "check:opensdk:all": "npm run check:opensdk && npm run check:opensdk:component-runtime && npm run check:opensdk:multilang && npm run check:opensdk:browser-frameworks && npm run check:opensdk:tooling",
    "build:opensdk:rust-component": "node scripts/build-opensdk-rust-component.mjs",
    "check:telemetry": "node scripts/check-telemetry-contract.mjs",
    "check:site": "node scripts/check-pliegors-site.mjs examples/pliegors-site/target/site",
    "check:site-deployment": "npm --prefix workers/pliegors-site run check",
    "check:wasm-lifetimes": "node scripts/check-wasm-lifetimes.mjs",
    "check:phase-1": "node scripts/check-phase-1.mjs",
    "check:phase-1-closure": "node scripts/check-phase-1-closure.mjs",
    "test:phase-1": "node --test tools/route-lab/*.test.mjs scripts/*.test.mjs crates/pliego-adapters/tests/*.test.mjs",
    "test:adapters": "node --test crates/pliego-adapters/tests/*.test.mjs",
    "test:adapters:browser": "node scripts/test-adapters-browser.mjs",
    "test:route-lab": "node --test tools/route-lab/*.test.mjs",
    "publish:crates": "node scripts/publish-crates.mjs --publish"
  },
  "devDependencies": {
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "esbuild": "^0.28.1",
    "gsap": "^3.13.0",
    "lenis": "^1.3.23",
    "lit": "3.3.3",
    "parse5": "^8.0.0",
    "playwright-core": "1.61.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "svelte": "5.56.6"
  }
