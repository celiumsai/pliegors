{
  "name": "@pliego/pliegors-workspace",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "bundle:phase-1-evidence": "node scripts/bundle-phase-1-evidence.mjs",
    "check:docs": "node scripts/check-doc-links.mjs",
    "check:distribution": "node scripts/check-distribution.mjs",
    "check:email-worker": "npm --prefix workers/pliegors-email run check",
    "check:site": "node scripts/check-pliegors-site.mjs examples/pliegors-site/target/site",
    "check:site-deployment": "npm --prefix workers/pliegors-site run check",
    "check:wasm-lifetimes": "node scripts/check-wasm-lifetimes.mjs",
    "check:phase-1": "node scripts/check-phase-1.mjs",
    "check:phase-1-closure": "node scripts/check-phase-1-closure.mjs",
    "test:phase-1": "node --test tools/route-lab/*.test.mjs scripts/*.test.mjs crates/pliego-adapters/tests/*.test.mjs",
    "test:adapters": "node --test crates/pliego-adapters/tests/*.test.mjs",
    "test:adapters:browser": "node scripts/test-adapters-browser.mjs",
    "test:route-lab": "node --test tools/route-lab/*.test.mjs"
  },
  "devDependencies": {
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "esbuild": "^0.28.1",
    "gsap": "^3.13.0",
    "lenis": "^1.3.23",
    "parse5": "^8.0.0"
  }
}
