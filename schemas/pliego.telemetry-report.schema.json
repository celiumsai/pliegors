{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pliegors.dev/schemas/pliego.telemetry-report.schema.json",
  "title": "PliegoRS voluntary telemetry report",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract", "generatedAtDay", "consent", "fields", "events"],
  "properties": {
    "contract": { "const": "dev.pliegors.telemetry-report/v1" },
    "generatedAtDay": { "type": "integer", "minimum": 0 },
    "consent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "policyVersion", "enabledAtDay"],
      "properties": {
        "enabled": { "type": "boolean" },
        "policyVersion": { "const": "1.0.0" },
        "enabledAtDay": { "type": ["integer", "null"], "minimum": 0 }
      }
    },
    "fields": {
      "const": [
        "sequence",
        "event",
        "daySinceUnixEpoch",
        "cliVersion",
        "platform",
        "architecture"
      ]
    },
    "events": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "sequence",
          "event",
          "daySinceUnixEpoch",
          "cliVersion",
          "platform",
          "architecture"
        ],
        "properties": {
          "sequence": { "type": "integer", "minimum": 0 },
          "event": { "enum": ["install", "new", "check", "dev", "build"] },
          "daySinceUnixEpoch": { "type": "integer", "minimum": 0 },
          "cliVersion": {
            "type": "string",
            "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$",
            "maxLength": 128
          },
          "platform": { "type": "string", "minLength": 1, "maxLength": 32 },
          "architecture": { "type": "string", "minLength": 1, "maxLength": 32 }
        }
      }
    }
  }
}
