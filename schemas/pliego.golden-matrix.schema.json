{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pliegors.dev/schemas/pliego.golden-matrix.schema.json",
  "title": "PliegoRS P8 golden environment matrix",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract", "version", "revision", "mode", "dependencySource", "createdAt", "complete", "reports", "limitations"],
  "properties": {
    "contract": { "const": "dev.pliegors.p8-golden-matrix/v1" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$" },
    "revision": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "mode": { "enum": ["candidate", "draft"] },
    "dependencySource": { "enum": ["candidate-source", "registry"] },
    "createdAt": { "type": "string", "format": "date-time" },
    "complete": { "type": "boolean" },
    "reports": {
      "type": "array",
      "minItems": 8,
      "maxItems": 9,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["environmentId", "target", "scenario", "hostPlatform", "hostArchitecture", "reportSha256", "cliSha256", "releaseManifestSha256", "reproductionBundleSha256", "totalDurationMs"],
        "properties": {
          "environmentId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,63}$" },
          "target": { "type": "string", "minLength": 1 },
          "scenario": { "enum": ["standard", "unicode", "long-path"] },
          "hostPlatform": { "enum": ["linux", "darwin", "win32"] },
          "hostArchitecture": { "enum": ["x64", "arm64"] },
          "reportSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "cliSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "releaseManifestSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "reproductionBundleSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "totalDurationMs": { "type": "number", "minimum": 0 }
        }
      }
    },
    "limitations": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
  }
}
