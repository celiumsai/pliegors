{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pliegors.dev/schemas/pliego.sdk-compatibility-matrix.schema.json",
  "title": "PliegoRS OpenSDK compatibility matrix",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract", "protocolVersion", "source", "hosts", "toolchains", "surfaces", "deprecations"],
  "properties": {
    "contract": { "const": "dev.pliegors.sdk-compatibility/v1" },
    "protocolVersion": { "const": "0.1.0-preview.1" },
    "source": { "const": "celiumsai/pliegors" },
    "hosts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "items": { "$ref": "#/$defs/host" }
    },
    "toolchains": {
      "type": "array",
      "minItems": 3,
      "maxItems": 128,
      "items": { "$ref": "#/$defs/toolchain" }
    },
    "surfaces": {
      "type": "array",
      "minItems": 5,
      "maxItems": 256,
      "items": { "$ref": "#/$defs/surface" }
    },
    "deprecations": {
      "type": "array",
      "maxItems": 256,
      "items": { "$ref": "#/$defs/deprecation" }
    }
  },
  "$defs": {
    "strings": {
      "type": "array",
      "maxItems": 256,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 128 }
    },
    "host": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "apiVersions", "stability", "planes", "features"],
      "properties": {
        "version": { "type": "string", "minLength": 1, "maxLength": 64 },
        "apiVersions": { "$ref": "#/$defs/strings" },
        "stability": { "enum": ["experimental", "preview", "stable"] },
        "planes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "uniqueItems": true,
          "items": { "enum": ["build", "server", "browser", "tooling"] }
        },
        "features": { "$ref": "#/$defs/strings" }
      }
    },
    "toolchain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "language", "boundary", "support", "testedVersion", "checks"],
      "properties": {
        "id": { "type": "string", "maxLength": 128, "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "language": { "type": "string", "minLength": 1, "maxLength": 128 },
        "boundary": { "enum": ["component-model", "process-bridge", "http-bridge"] },
        "support": { "enum": ["reference", "conformance", "experimental"] },
        "testedVersion": { "type": "string", "minLength": 1, "maxLength": 128 },
        "checks": { "$ref": "#/$defs/strings" }
      }
    },
    "surface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "protocol", "testedVersion", "checks"],
      "properties": {
        "id": { "type": "string", "maxLength": 128, "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "protocol": { "enum": ["browser-component", "json-rpc", "mcp"] },
        "testedVersion": { "type": "string", "minLength": 1, "maxLength": 128 },
        "checks": { "$ref": "#/$defs/strings" }
      }
    },
    "deprecation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "state", "since", "earliestRemoval", "replacement"],
      "properties": {
        "id": { "type": "string", "maxLength": 128, "pattern": "^[a-z0-9]+(?:[./-][a-z0-9]+)*$" },
        "state": { "enum": ["active", "deprecated", "removed"] },
        "since": { "type": "string", "minLength": 1, "maxLength": 64 },
        "earliestRemoval": {
          "anyOf": [
            { "type": "string", "minLength": 1, "maxLength": 64 },
            { "type": "null" }
          ]
        },
        "replacement": {
          "anyOf": [
            { "type": "string", "maxLength": 128, "pattern": "^[a-z0-9]+(?:[./-][a-z0-9]+)*$" },
            { "type": "null" }
          ]
        }
      }
    }
  }
}
