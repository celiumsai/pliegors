{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pliegors.dev/schemas/pliego.measurement-report.schema.json",
  "title": "PLIEGO physical measurement report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "reportVersion",
    "planVersion",
    "capturedAt",
    "deviceId",
    "hardwareFingerprint",
    "browserFingerprint",
    "targetId",
    "route",
    "tier",
    "cacheMode",
    "orientation",
    "motionMode",
    "sourceRevision",
    "networkProfile",
    "powerState",
    "thermalState",
    "rejectedRunCount",
    "runCount",
    "observations",
    "evidence"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "reportVersion": {
      "const": "1.1.0"
    },
    "planVersion": {
      "const": "1.0.0"
    },
    "capturedAt": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?Z$"
    },
    "deviceId": {
      "type": "string",
      "minLength": 1
    },
    "hardwareFingerprint": {
      "type": "string",
      "minLength": 1
    },
    "browserFingerprint": {
      "type": "string",
      "minLength": 1
    },
    "targetId": {
      "type": "string",
      "minLength": 1
    },
    "route": {
      "type": "string",
      "pattern": "^/"
    },
    "tier": {
      "type": "string",
      "enum": [
        "universal",
        "lite",
        "balanced",
        "signature"
      ]
    },
    "cacheMode": {
      "type": "string",
      "enum": [
        "cold",
        "warm"
      ]
    },
    "orientation": {
      "type": "string",
      "enum": [
        "portrait",
        "landscape"
      ]
    },
    "motionMode": {
      "type": "string",
      "enum": [
        "default",
        "reduced"
      ]
    },
    "sourceRevision": {
      "type": "string",
      "minLength": 1
    },
    "networkProfile": {
      "type": "string",
      "minLength": 1
    },
    "powerState": {
      "type": "string",
      "enum": [
        "external-power",
        "battery-over-50"
      ]
    },
    "thermalState": {
      "const": "nominal"
    },
    "rejectedRunCount": {
      "type": "integer",
      "minimum": 0
    },
    "runCount": {
      "type": "integer",
      "minimum": 5
    },
    "observations": {
      "$ref": "#/$defs/observations"
    },
    "evidence": {
      "$ref": "#/$defs/evidence"
    }
  },
  "$defs": {
    "observations": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "transferBytes",
        "decodeP95Ms",
        "mainThreadP95Ms",
        "estimatedVramBytes",
        "drawCalls",
        "triangles",
        "frameP95Ms",
        "lcpP75Ms",
        "inpP75Ms",
        "clsP75"
      ],
      "properties": {
        "transferBytes": {
          "type": "integer",
          "minimum": 0
        },
        "decodeP95Ms": {
          "type": "number",
          "minimum": 0
        },
        "mainThreadP95Ms": {
          "type": "number",
          "minimum": 0
        },
        "estimatedVramBytes": {
          "type": "integer",
          "minimum": 0
        },
        "drawCalls": {
          "type": "integer",
          "minimum": 0
        },
        "triangles": {
          "type": "integer",
          "minimum": 0
        },
        "frameP95Ms": {
          "type": "number",
          "minimum": 0
        },
        "lcpP75Ms": {
          "type": "number",
          "minimum": 0
        },
        "inpP75Ms": {
          "type": "number",
          "minimum": 0
        },
        "clsP75": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "collectorVersion",
        "tracePath",
        "traceSha256",
        "traceMetricsPath",
        "traceMetricsSha256",
        "screenshotPath",
        "screenshotSha256",
        "rawRunsPath"
      ],
      "properties": {
        "collectorVersion": {
          "type": "string",
          "minLength": 1
        },
        "tracePath": {
          "type": "string",
          "minLength": 1
        },
        "traceSha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "traceMetricsPath": {
          "type": "string",
          "minLength": 1
        },
        "traceMetricsSha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "screenshotPath": {
          "type": "string",
          "minLength": 1
        },
        "screenshotSha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "rawRunsPath": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
