{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "pliegors-email",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-14",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": false,
  "observability": {
    "enabled": true,
    "head_sampling_rate": 0.1
  },
  "env": {
    "staging": {
      "name": "pliegors-email-staging",
      "observability": {
        "enabled": true,
        "head_sampling_rate": 1
      }
    }
  }
}
